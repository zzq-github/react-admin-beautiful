# App identity
VITE_APP_NAME=React Admin Beautiful
VITE_APP_SHORT_NAME=R
VITE_APP_DESCRIPTION=Admin Platform
VITE_APP_COPYRIGHT=(c) 2026 React Admin Beautiful

# Routes
VITE_APP_DEFAULT_ROUTE=/dashboard
VITE_APP_LOGIN_ROUTE=/login
VITE_APP_NOTIFY_ROUTE=/user/notify-message

# API
# Use an empty VITE_BASE_API with Vite proxy in development.
# Use a full backend origin in production, for example https://api.example.com.
VITE_BASE_API=
VITE_API_PREFIX=/api
VITE_PROXY_TARGET=http://localhost:8080

# Feature switches
VITE_CAPTCHA_ENABLE=false
VITE_MSW_ENABLE=true
