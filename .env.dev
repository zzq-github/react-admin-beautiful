# 开发环境配置
ENV = 'development'

# 应用信息
VITE_APP_NAME = React Admin Plus
VITE_APP_SHORT_NAME = R
VITE_APP_DESCRIPTION = Admin Platform
VITE_APP_COPYRIGHT = (c) 2026 React Admin Plus

# 路由配置
VITE_APP_DEFAULT_ROUTE = /dashboard
VITE_APP_LOGIN_ROUTE = /login
VITE_APP_NOTIFY_ROUTE = /user/notify-message

# 兼容旧配置：页面标题
VITE_TITLE = React Admin Plus

# 后端 API 基础路径
# 使用 Vite Proxy 时设为空字符串，请求走代理
# 如果不使用代理，设为后端完整地址如 'http://localhost:8080'
VITE_BASE_API = ''

# API 请求前缀（配合 Vite proxy 使用）
VITE_API_PREFIX = /api

# Vite 代理目标
VITE_PROXY_TARGET = http://localhost:8080

# 验证码开关
VITE_CAPTCHA_ENABLE = false

# MSW Mock 开关（无后端时设为 true，有后端时设为 false）
VITE_MSW_ENABLE = true

# 开发辅助插件开关
VITE_TAGGER_ENABLE = false
