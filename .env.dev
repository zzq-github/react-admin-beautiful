# 开发环境配置
ENV = 'development'

# 页面标题
VITE_TITLE = 管理系统

# 管理系统/开发环境
# 使用 Vite Proxy 时设为空字符串，请求走 /admin-api/ 代理
# 如果不使用代理，设为后端完整地址如 'http://192.168.0.249:48089'
VITE_BASE_API = ''

# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES = true

# 多租户的开关
VITE_TENANT_ENABLE = false
# 验证码的开关
VITE_CAPTCHA_ENABLE = false

# 文档的开关
VITE_DOC_ENABLE = false

# MSW Mock 开关（无后端时设为 true，有后端时设为 false）
VITE_MSW_ENABLE = true

# 百度统计
VITE_BAIDU_CODE = fadc1bd5db1a1d6f581df60a1807f8ab
